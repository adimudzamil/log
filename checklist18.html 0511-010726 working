<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Checklist 18 – Document List</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        /* ══════════════════════════════════════════
           THEME VARIABLES (mirroring dashboard)
        ══════════════════════════════════════════ */
        :root {
            --bg: #F4F7FB;
            --surface: #FFFFFF;
            --surface2: #EEF3FA;
            --border: #D6E0EF;
            --border2: #C0CFDF;
            --text: #0D1F3C;
            --text2: #4A6280;
            --text3: #8FA3BC;
            --navy: #003580;
            --navy2: #001F4E;
            --navy3: #00418A;
            --gold: #C9A84C;
            --gold2: #E8C96A;
            --shadow: 0 2px 12px rgba(0, 31, 78, 0.08);
            --shadow2: 0 8px 30px rgba(0, 31, 78, 0.12);
            --radius: 14px;
            --radius-sm: 10px;
            --transition: 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
            --selected-bg: #E3F0FA;
            --selected-border: #1A85C7;
            --selected-text: #005A9C;
        }

        [data-theme="ops"] {
            --bg: #F4F7FB;
            --surface: #FFFFFF;
            --surface2: #EEF3FA;
            --border: #D6E0EF;
            --border2: #C0CFDF;
            --text: #0D1F3C;
            --text2: #4A6280;
            --text3: #8FA3BC;
            --navy: #003580;
            --navy2: #001F4E;
            --navy3: #00418A;
            --gold: #C9A84C;
            --gold2: #E8C96A;
            --shadow: 0 2px 12px rgba(0, 31, 78, 0.08);
            --shadow2: 0 8px 30px rgba(0, 31, 78, 0.12);
            --selected-bg: #E3F0FA;
            --selected-border: #1A85C7;
            --selected-text: #005A9C;
        }

        [data-theme="dark"] {
            --bg: #0D1525;
            --surface: #162035;
            --surface2: #1C2A42;
            --border: #243350;
            --border2: #2E4070;
            --text: #E8EEF7;
            --text2: #8FA3BC;
            --text3: #4A6280;
            --shadow: 0 2px 12px rgba(0, 0, 0, .3);
            --shadow2: 0 8px 30px rgba(0, 0, 0, .4);
            --selected-bg: #1C3A5A;
            --selected-border: #4A8FC7;
            --selected-text: #9BC9FF;
        }

        [data-theme="black"] {
            --bg: #000;
            --surface: #0A0A0A;
            --surface2: #111;
            --border: #1A1A1A;
            --border2: #222;
            --text: #F0F0F0;
            --text2: #888;
            --text3: #444;
            --shadow: 0 2px 12px rgba(0, 0, 0, .6);
            --shadow2: 0 8px 30px rgba(0, 0, 0, .8);
            --selected-bg: #1A1A2E;
            --selected-border: #666;
            --selected-text: #AAA;
        }

        [data-theme="modern"] {
            --bg: #F0F4FF;
            --surface: #FFFFFF;
            --surface2: #EBF2FF;
            --border: #C7D7F7;
            --border2: #A0BBF0;
            --text: #1E293B;
            --text2: #475569;
            --text3: #94A3B8;
            --navy: #1D4ED8;
            --navy2: #1E3A8A;
            --navy3: #2563EB;
            --gold: #F59E0B;
            --gold2: #FCD34D;
            --shadow: 0 2px 12px rgba(30, 58, 138, 0.08);
            --shadow2: 0 8px 30px rgba(30, 58, 138, 0.14);
            --selected-bg: #EFF6FF;
            --selected-border: #1D4ED8;
            --selected-text: #1E3A8A;
        }

        [data-theme="jarvis"] {
            --bg: #0A0E1A;
            --surface: #111827;
            --surface2: #1A2332;
            --border: #2D3A4F;
            --border2: #3B4D6B;
            --text: #E2E8F0;
            --text2: #94A3B8;
            --text3: #475569;
            --navy: #00B4D8;
            --navy2: #0077B6;
            --navy3: #00B4D8;
            --gold: #00E5FF;
            --gold2: #4DD0E1;
            --shadow: 0 2px 12px rgba(0, 180, 216, 0.15);
            --shadow2: 0 8px 30px rgba(0, 180, 216, 0.2);
            --selected-bg: #0A2A3A;
            --selected-border: #00B4D8;
            --selected-text: #80E0FF;
        }

        [data-theme="cyberpunk"] {
            --bg: #0B0A0F;
            --surface: #1A1425;
            --surface2: #251F33;
            --border: #3A2D4A;
            --border2: #5A3D6A;
            --text: #F0E6FF;
            --text2: #B89FD0;
            --text3: #6A4F7A;
            --navy: #FF007F;
            --navy2: #CC0066;
            --navy3: #FF2E9C;
            --gold: #00FFD1;
            --gold2: #66FFE0;
            --shadow: 0 2px 12px rgba(255, 0, 127, 0.2);
            --shadow2: 0 8px 30px rgba(255, 0, 127, 0.25);
            --selected-bg: #2A0A20;
            --selected-border: #FF007F;
            --selected-text: #FF66B2;
        }

        /* ══════════════════════════════════════════
           NEW THEMES
        ══════════════════════════════════════════ */

        /* ── EARTHY (Louis Vuitton inspired) ── */
        [data-theme="earthy"] {
            --bg: #F5F0E8;
            --surface: #E8DCC8;
            --surface2: #D4C5A9;
            --border: #A68B6D;
            --border2: #8B6B3A;
            --text: #2C1A1A;
            --text2: #7A5A3A;
            --text3: #B89A7A;
            --navy: #C5A55A;
            --navy2: #4A2C2A;
            --navy3: #D4B86A;
            --gold: #C5A55A;
            --gold2: #D4B86A;
            --shadow: 0 2px 12px rgba(74, 44, 42, 0.12);
            --shadow2: 0 8px 30px rgba(74, 44, 42, 0.18);
            --selected-bg: #D4C5A9;
            --selected-border: #C5A55A;
            --selected-text: #4A2C2A;
        }

        /* ── MILITARY (Camo Green/Sand) ── */
        [data-theme="military"] {
            --bg: #2E3A2E;
            --surface: #3A4A3A;
            --surface2: #4A5A4A;
            --border: #5A6A5A;
            --border2: #6A7A6A;
            --text: #E8F0E8;
            --text2: #B0C0B0;
            --text3: #7A8A7A;
            --navy: #8B9A6B;
            --navy2: #1A2A1A;
            --navy3: #A0B08A;
            --gold: #C4A86B;
            --gold2: #D4B88A;
            --shadow: 0 2px 12px rgba(0, 0, 0, 0.35);
            --shadow2: 0 8px 30px rgba(0, 0, 0, 0.45);
            --selected-bg: #5A6A5A;
            --selected-border: #C4A86B;
            --selected-text: #E8F0E8;
        }

        /* ── GOAT (Qatar Airways inspired) ── */
        [data-theme="goat"] {
            --bg: #1A0A0A;
            --surface: #2A1418;
            --surface2: #3A1E24;
            --border: #5A2A30;
            --border2: #7A3A40;
            --text: #F0E8E0;
            --text2: #C8A890;
            --text3: #8A6A5A;
            --navy: #8A1A2A;
            --navy2: #4A0A12;
            --navy3: #A02A3A;
            --gold: #C9A84C;
            --gold2: #E8C96A;
            --shadow: 0 2px 12px rgba(74, 10, 18, 0.5);
            --shadow2: 0 8px 30px rgba(74, 10, 18, 0.6);
            --selected-bg: #3A1E24;
            --selected-border: #C9A84C;
            --selected-text: #F0E8E0;
        }

        /* ══════════════════════════════════════════
           RESET & BASE
        ══════════════════════════════════════════ */
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            transition: background var(--transition), color var(--transition);
            -webkit-font-smoothing: antialiased;
        }

        /* ══════════════════════════════════════════
           MAIN CARD
        ══════════════════════════════════════════ */
        .container {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow2);
            padding: 32px 28px 36px;
            max-width: 640px;
            width: 100%;
            transition: background var(--transition), border-color var(--transition);
        }

        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 8px;
        }
        .header h1 {
            font-size: 1.3rem;
            font-weight: 800;
            letter-spacing: -0.02em;
            color: var(--text);
        }
        .header h1 em {
            color: var(--gold);
            font-style: normal;
        }
        .header .count {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text2);
            background: var(--surface2);
            padding: 4px 14px;
            border-radius: 20px;
            border: 1px solid var(--border);
        }
        .header .count span {
            color: var(--navy);
            font-weight: 800;
        }

        /* ══════════════════════════════════════════
           ITEMS GRID
        ══════════════════════════════════════════ */
        .items-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 24px;
        }
        @media (max-width: 480px) {
            .items-grid {
                grid-template-columns: 1fr;
            }
        }

        .item {
            padding: 12px 16px;
            border-radius: var(--radius-sm);
            border: 2px solid var(--border);
            background: var(--surface2);
            cursor: pointer;
            transition: all var(--transition);
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--text2);
            text-align: left;
            display: flex;
            align-items: center;
            gap: 10px;
            user-select: none;
            font-family: 'Inter', sans-serif;
            line-height: 1.3;
        }
        .item:hover {
            border-color: var(--border2);
            transform: translateY(-1px);
        }
        .item .checkbox {
            width: 20px;
            height: 20px;
            border-radius: 6px;
            border: 2px solid var(--border2);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all var(--transition);
            background: var(--surface);
            font-size: 12px;
            color: transparent;
        }
        .item.selected {
            border-color: var(--selected-border);
            background: var(--selected-bg);
            color: var(--selected-text);
            box-shadow: 0 0 0 3px rgba(26, 133, 199, 0.1);
        }
        .item.selected .checkbox {
            border-color: var(--selected-border);
            background: var(--selected-border);
            color: #fff;
        }
        .item .label {
            flex: 1;
        }

        /* ══════════════════════════════════════════
           ACTIONS
        ══════════════════════════════════════════ */
        .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            align-items: center;
            justify-content: center;
            border-top: 1px solid var(--border);
            padding-top: 20px;
            margin-top: 4px;
        }
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 22px;
            border: none;
            border-radius: 30px;
            font-weight: 700;
            font-size: 0.85rem;
            font-family: 'Inter', sans-serif;
            transition: all var(--transition);
            cursor: pointer;
            letter-spacing: 0.02em;
        }
        .btn:active {
            transform: scale(0.96);
        }
        .btn-primary {
            background: var(--navy);
            color: #fff;
            box-shadow: var(--shadow);
        }
        .btn-primary:hover {
            background: var(--navy3);
            transform: translateY(-2px);
            box-shadow: var(--shadow2);
        }
        .btn-gold {
            background: var(--gold);
            color: var(--navy2);
            box-shadow: var(--shadow);
        }
        .btn-gold:hover {
            background: var(--gold2);
            transform: translateY(-2px);
            box-shadow: var(--shadow2);
        }
        .btn-outline {
            background: transparent;
            color: var(--text2);
            border: 2px solid var(--border);
        }
        .btn-outline:hover {
            border-color: var(--text2);
            color: var(--text);
            background: var(--surface2);
        }
        .btn .icon {
            font-size: 1.1rem;
        }
        .btn .badge {
            font-size: 0.6rem;
            background: rgba(255, 255, 255, 0.2);
            padding: 2px 10px;
            border-radius: 20px;
            font-weight: 600;
        }
        .btn-gold .badge {
            background: rgba(0, 0, 0, 0.1);
            color: var(--navy2);
        }

        .toast-msg {
            font-size: 0.8rem;
            color: var(--gold);
            font-weight: 500;
            opacity: 0;
            transition: opacity 0.3s;
        }
        .toast-msg.show {
            opacity: 1;
        }

        /* ══════════════════════════════════════════
           RESPONSIVE
        ══════════════════════════════════════════ */
        @media (max-width: 480px) {
            .container {
                padding: 20px 16px 24px;
            }
            .item {
                font-size: 0.8rem;
                padding: 10px 14px;
            }
            .btn {
                font-size: 0.75rem;
                padding: 8px 16px;
            }
            .header h1 {
                font-size: 1.1rem;
            }
        }
    </style>
</head>
<body>

    <div class="container" id="app">
        <!-- Header -->
        <div class="header">
            <h1>Checklist <em>18</em></h1>
            <div class="count">Selected: <span id="selectedCount">0</span> / <span id="totalCount">0</span></div>
        </div>

        <!-- Items Grid -->
        <div class="items-grid" id="itemsGrid">
            <!-- rendered by JS -->
        </div>

        <!-- Actions -->
        <div class="actions">
            <button class="btn btn-gold" id="copyBtn">
                <span class="icon">📋</span> Copy Selected
                <span class="badge">Ctrl+C</span>
            </button>
            <button class="btn btn-outline" id="deselectBtn">
                <span class="icon">✕</span> Deselect All
            </button>
            <span class="toast-msg" id="toastMsg">✓ Copied!</span>
        </div>
    </div>

    <script>
        'use strict';

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  DATA
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        const ITEMS = [
            { id: 'ind-baggage', label: 'IND baggage declaration form' },
            { id: 'ind-arrival', label: 'IND arrival form' },
            { id: 'bkk-passport', label: 'BKK passport pic / signed form' },
            { id: 'aus-465', label: 'AUS 465 declaration form' },
            { id: 'jpn-declaration', label: 'JPN declaration form' },
            { id: 'fumigation', label: 'Fumigation Form / Cans' },
            { id: 'gendec', label: 'GenDec' },
            { id: 'special-handling', label: 'Special Handling Form' },
            { id: 'health-ebola', label: 'Health form (Ebola etc.)' },
            { id: 'ypta-um', label: 'YPTA / UM documents' },
            { id: 'pregnancy', label: 'Pregnancy form' },
            { id: 'allergy', label: 'Allergy form' },
            { id: 'ntl-depo', label: 'NTL / Depo form' },
        ];

        const STORAGE_KEY = 'checklist18_selected';

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  STATE
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        let selectedIds = new Set();

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  DOM REFS
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        const itemsGrid = document.getElementById('itemsGrid');
        const selectedCountEl = document.getElementById('selectedCount');
        const totalCountEl = document.getElementById('totalCount');
        const copyBtn = document.getElementById('copyBtn');
        const deselectBtn = document.getElementById('deselectBtn');
        const toastMsg = document.getElementById('toastMsg');

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  THEME SYNC (from parent iframe)
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        function syncTheme() {
            const params = new URLSearchParams(window.location.search);
            const theme = params.get('theme') || 'ops';
            // Check if the theme is valid – if not, fall back to 'ops'
            const validThemes = ['ops', 'dark', 'black', 'modern', 'jarvis', 'cyberpunk', 'earthy', 'military', 'goat'];
            const finalTheme = validThemes.includes(theme) ? theme : 'ops';
            document.body.setAttribute('data-theme', finalTheme);
            localStorage.setItem('dashboard_theme', finalTheme);
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  PERSISTENCE
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        function loadSelections() {
            const stored = localStorage.getItem(STORAGE_KEY);
            if (stored) {
                try {
                    const arr = JSON.parse(stored);
                    if (Array.isArray(arr)) {
                        selectedIds = new Set(arr);
                        return;
                    }
                } catch (_) { /* ignore */ }
            }
            // Default: none selected
            selectedIds = new Set();
        }

        function saveSelections() {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(Array.from(selectedIds)));
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  RENDER
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        function render() {
            totalCountEl.textContent = ITEMS.length;

            let html = '';
            ITEMS.forEach(item => {
                const selected = selectedIds.has(item.id);
                html += `
                    <div class="item ${selected ? 'selected' : ''}" data-id="${item.id}">
                        <div class="checkbox">${selected ? '✓' : ''}</div>
                        <span class="label">${item.label}</span>
                    </div>
                `;
            });
            itemsGrid.innerHTML = html;

            // Update count
            selectedCountEl.textContent = selectedIds.size;

            // ── Click events ──
            itemsGrid.querySelectorAll('.item').forEach(el => {
                el.addEventListener('click', () => {
                    const id = el.dataset.id;
                    toggleItem(id);
                });
            });

            // ── Keyboard shortcut: Ctrl+A to select all ──
            // (handled globally)
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  ACTIONS
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        function toggleItem(id) {
            if (selectedIds.has(id)) {
                selectedIds.delete(id);
            } else {
                selectedIds.add(id);
            }
            saveSelections();
            render();
        }

        function selectAll() {
            ITEMS.forEach(item => selectedIds.add(item.id));
            saveSelections();
            render();
        }

        function deselectAll() {
            selectedIds.clear();
            saveSelections();
            render();
        }

        function getSelectedLabels() {
            return ITEMS
                .filter(item => selectedIds.has(item.id))
                .map(item => item.label);
        }

        function getSummaryText() {
            const labels = getSelectedLabels();
            if (labels.length === 0) return 'No items selected.';
            return labels.map(label => `• ${label}`).join('\n');
        }

        function copySummary() {
            const text = getSummaryText();
            if (text === 'No items selected.') {
                toastMsg.textContent = '⚠️ Nothing selected.';
                toastMsg.classList.add('show');
                setTimeout(() => toastMsg.classList.remove('show'), 1500);
                return;
            }

            navigator.clipboard.writeText(text).then(() => {
                toastMsg.textContent = '✓ Copied!';
                toastMsg.classList.add('show');
                setTimeout(() => toastMsg.classList.remove('show'), 2000);
            }).catch(() => {
                // Fallback
                const ta = document.createElement('textarea');
                ta.value = text;
                document.body.appendChild(ta);
                ta.select();
                document.execCommand('copy');
                document.body.removeChild(ta);
                toastMsg.textContent = '✓ Copied!';
                toastMsg.classList.add('show');
                setTimeout(() => toastMsg.classList.remove('show'), 2000);
            });
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  KEYBOARD SHORTCUTS
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        document.addEventListener('keydown', (e) => {
            // Ctrl+A → Select All
            if ((e.ctrlKey || e.metaKey) && e.key === 'a') {
                const tag = document.activeElement?.tagName || '';
                if (!['INPUT', 'TEXTAREA', 'SELECT'].includes(tag)) {
                    e.preventDefault();
                    selectAll();
                    toastMsg.textContent = '✓ All selected';
                    toastMsg.classList.add('show');
                    setTimeout(() => toastMsg.classList.remove('show'), 1200);
                }
            }
            // Ctrl+C → Copy (only if not in input/textarea)
            if ((e.ctrlKey || e.metaKey) && e.key === 'c') {
                const tag = document.activeElement?.tagName || '';
                if (!['INPUT', 'TEXTAREA', 'SELECT'].includes(tag)) {
                    e.preventDefault();
                    copySummary();
                }
            }
        });

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        //  INIT
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

        function init() {
            syncTheme();
            loadSelections();
            render();

            // ── Button events ──
            copyBtn.addEventListener('click', copySummary);
            deselectBtn.addEventListener('click', deselectAll);

            console.log('📋 Checklist 18 ready');
        }

        document.addEventListener('DOMContentLoaded', init);
    </script>

</body>
</html>